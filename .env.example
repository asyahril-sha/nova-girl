# API Keys (WAJIB)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_TOKEN=your_telegram_bot_token_here

# Admin (opsional - untuk fitur admin)
ADMIN_ID=your_telegram_user_id

# Database (opsional - default sudah ada)
DB_PATH=gadis_v60.db

# AI Settings (opsional)
AI_TEMPERATURE=0.9
AI_MAX_TOKENS=300
AI_TIMEOUT=30

# Rate Limiting (opsional)
MAX_MESSAGES_PER_MINUTE=10

# Cache (opsional)
CACHE_TIMEOUT=300
